{
  "manifest_version": 3,
  "name": "Chat Outline Sidebar (Local)",
  "version": "0.2.0",
  "version_name": "0.2.0 (© 2026 tojicb-fushiguro • CO-SIDEBAR-6C1E-2026)",
  "description": "Adds an in-chat message outline sidebar for ChatGPT, Gemini, and Perplexity.",
  "homepage_url": "https://github.com/tojicb-fushiguro/Chat-Outline",
  "permissions": ["storage"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*"
      ],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
